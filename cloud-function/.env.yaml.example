# ==========================================
# .env.yaml.example
# ==========================================
# 이 파일을 복사하여 .env.yaml로 저장 후 실제 값으로 교체하세요.
#
# cp .env.yaml.example .env.yaml
#
# .env.yaml은 .gitignore에 포함되어 GitHub에 올라가지 않습니다.
# ==========================================

# Google Apps Script Webhook URL (Sheets 저장용)
# 예: https://script.google.com/macros/s/ABCDEF.../exec
SHEETS_WEBHOOK_URL: "YOUR_SHEETS_WEBHOOK_URL_HERE"

# Slack Incoming Webhook URL
# 예: https://hooks.slack.com/services/T.../B.../...
SLACK_WEBHOOK_URL: "YOUR_SLACK_WEBHOOK_URL_HERE"

# GCP 프로젝트 ID
GCP_PROJECT_ID: "my-project-yeo-website-492002"

# CORS 허용 Origin (GitHub Pages URL)
# 예: https://taeyoonpark.github.io
ALLOWED_ORIGIN: "https://YOUR_GITHUB_USERNAME.github.io"
